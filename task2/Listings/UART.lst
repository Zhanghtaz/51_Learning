   1          #include <at89c51RC2.h>
   2          
   3          /**
   4            * @brief  串口初始化 4800bps@11.0592MHz
   5            * @param  无
   6            * @retval 无
   7            */
   8          
   9          void UART_Init()    //4800bps@11.0592MHz
  10          {
  11   1              SCON=0x50;
  12   1              PCON=0x00;
  13   1              TMOD &= 0x0F;           //设置定时器模式
  14   1              TMOD |= 0x20;           //设置定时器模式
  15   1              TL1 = 0xFA;             //设定定时初值
  16   1              TH1 = 0xFA;             //设定定时器重装值
  17   1              ET1 = 0;                //禁止定时器1中断
  18   1              TR1 = 1;                //启动定时器1
  19   1              EA=1;                   //启动总中断
  20   1              ES=1;                   //启动串口中断
  21   1      }
  22          
  23          /**
  24            * @brief  串口发送一个字节数据
  25            * @param      Byte 要发送的一个字节数据
  26            * @retval 无
  27            */
  28          
  29          void UART_SendByte(unsigned char Byte)
  30          {
  31   1              SBUF=Byte;
  32   1              while(TI==0);
  33   1              TI=0;
  34   1      }
